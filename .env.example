# Non-secret config only. NEVER put a token or API key here — everything in a
# Vite bundle (VITE_*) ships to every browser. The only credential this app holds
# is the user's own auth token, obtained at runtime via OTP login.

# Flash GraphQL endpoint.
# For local testing behind a tunnel, set this to /graphql to use the dev proxy
# (see vite.config.ts) and avoid Flash's CORS allowlist.
VITE_FLASH_API_URL=https://api.flashapp.me/graphql

# Geetest captcha product id used by Flash's web login (public, not a secret).
# There is no login bypass — login always runs the real captcha. Override only if
# Flash changes the geetest product id.
VITE_GEETEST_PRODUCT=bind

# --- Feature flags (all default to true; see src/flags.ts) ---
# Accepts true/false, on/off, 1/0, yes/no. Unset = default.
# VITE_FEATURE_BRIDGE=true            # Move tab (Lightning bridge)
# VITE_FEATURE_SEND=true              # Send tab (intraledger USD)
# VITE_FEATURE_RECEIVE=true           # Receive tab (LN invoice)
# VITE_FEATURE_CASHOUT=true           # Cash out tab (bank withdrawal)
# VITE_FEATURE_BRIDGE_WITHDRAW=true   # sub-flag: Flash → Fedi withdraw direction
# VITE_FEATURE_OTP_WHATSAPP=true      # sub-flag: WhatsApp OTP delivery channel
